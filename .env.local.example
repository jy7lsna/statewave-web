# Copy to `.env.local` and fill in your values. Both vars are required —
# `npm run dev`, `npm start`, and the Vercel adapter all throw
# StatewaveConfigError on the first /api request if either is missing.
#
# Local Statewave running via `docker compose up` in
# https://github.com/smaramwbc/statewave defaults to :8100.

STATEWAVE_URL=http://localhost:8100
STATEWAVE_API_KEY=your-local-api-key
